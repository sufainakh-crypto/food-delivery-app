const mongoose = require("mongoose");

const restaurantSchema = new mongoose.Schema({
    name: String,
    image: String,
    address: String,
    cuisine: String,
    ownerId: {
        type: mongoose.Schema.Types.ObjectId,
        ref: "User",
        default: null
    }
});

module.exports = mongoose.model(
  "Restaurant",
  restaurantSchema
);